{
  "name": "wiki-tui",
  "description": "OpenTUI + SolidJS frontend for mini-wiki",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build --compile --target=bun --outfile=dist/wiki-tui ./src/index.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.3.4",
    "@opentui/keymap": "0.3.4",
    "@opentui/solid": "0.3.4",
    "opentui-spinner": "0.0.7",
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@tsconfig/bun": "^1.0.9",
    "@types/bun": "^1.3.0"
  }
}
